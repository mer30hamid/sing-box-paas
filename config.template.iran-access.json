{
	"log": {
		"level": "warn"
	},
	"dns": {
		"servers": [
			{
				"tag": "dns_all",
				"type": "udp",
				"server": "IRAN_DNS_ALL"
			},
			{
				"tag": "dns_resolver",
				"type": "udp",
				"server": "IRAN_DNS_RESOLVER"
			}
		],
		"rules": [
			{
				"inbound": [
					"trojan",
					"vless",
					"vmess"
				],
				"server": "dns_all"
			}
		],
		"final": "dns_resolver",
		"strategy": "prefer_ipv4"
	},
	"inbounds": [
		{
			"type": "trojan",
			"tag": "trojan",
			"listen": "127.0.0.1",
			"listen_port": 30000,
			"sniff": true,
			"sniff_override_destination": true,
			"users": [
				{
					"password": "UUID"
				}
			],
			"tls": {
				"enabled": false
			},
			"transport": {
				"path": "/UUID-tr",
				"type": "ws"
			}
		},
		{
			"type": "vless",
			"tag": "vless",
			"listen": "127.0.0.1",
			"listen_port": 20000,
			"sniff": true,
			"sniff_override_destination": true,
			"users": [
				{
					"name": "abbas",
					"uuid": "UUID",
					"flow": ""
				}
			],
			"tls": {
				"enabled": false
			},
			"transport": {
				"path": "/UUID-vl",
				"type": "ws"
			}
		},
		{
			"type": "vmess",
			"tag": "vmess",
			"listen": "127.0.0.1",
			"listen_port": 10000,
			"sniff": true,
			"sniff_override_destination": true,
			"users": [
				{
					"name": "abbas",
					"uuid": "UUID"
				}
			],
			"tls": {
				"enabled": false
			},
			"transport": {
				"path": "/UUID-vm",
				"type": "ws"
			}
		}
	],
	"outbounds": [
		{
			"tag": "direct",
			"type": "direct"
		},
		{
			"tag": "bypass",
			"type": "direct"
		}
	],
	"route": {
		"auto_detect_interface": false,
		"default_domain_resolver": {
			"server": "dns_resolver",
			"strategy": "ipv4_only"
		},
		"rules": [
			{
				"action": "sniff"
			},
			{
				"protocol": "dns",
				"action": "hijack-dns"
			},
			{
				"ip_is_private": true,
				"action": "reject"
			},
			{
				"inbound": [
					"vmess",
					"vless",
					"trojan"
				],
				"outbound": "direct"
			}
		]
	},
	"experimental": {
		"cache_file": {
			"enabled": true
		}
	}
}